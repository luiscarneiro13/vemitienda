{
  "expo": {
    "name": "Ve mi Tienda",
    "slug": "ve_mi_tienda_col",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon2.png",
    "splash": {
      "image": "./assets/splash2.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Permitir a $(PRODUCT_NAME) acceder a tus fotos.",
        "NSPhotoLibraryAddUsageDescription": "Permitir a $(PRODUCT_NAME) guardar fotos."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "CAMERA_ROLL",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ],
      "package": "com.vemitienda.online.col",
      "versionCode": 1
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir a $(PRODUCT_NAME) acceder a tus fotos.",
          "savePhotosPermission": "Permitir a $(PRODUCT_NAME) guardar fotos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f3bdc941-935b-4f32-89f0-53255b5e28ec"
      }
    }
  }
}
